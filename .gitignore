# API keys and secrets
pipeline/.env
*.env

# Pipeline data (large JSON files, generated)
pipeline/data/*
# … but ex-ante frozen hypothesis artifacts MUST be committed
# (data validation policy §11.3 point-in-time correctness)
!pipeline/data/earnings_calendar/
pipeline/data/earnings_calendar/*
!pipeline/data/earnings_calendar/peers_frozen.json
# Universe pins (data validation policy §11.3 — point-in-time correctness)
!pipeline/data/canonical_fno_research_v*.json
# PIT regime tape package (loader code is tracked; daily snapshots are runtime data)
!pipeline/data/pit_regime_tape/
pipeline/data/pit_regime_tape/*
!pipeline/data/pit_regime_tape/__init__.py
!pipeline/data/pit_regime_tape/README.md
pipeline/logs/
pipeline/__pycache__/
pipeline/lib/
pipeline/artifacts/
pipeline/backtests/
pipeline/autoresearch/

# Test scripts
pipeline/test_*.py

# IDE
.claude/
.vscode/
__pycache__/
*.pyc

# Watchdog runtime state (regenerates each run)
pipeline/data/watchdog_state.json
pipeline/data/chart_audit_state.json

# Watchdog fallback alerts log (generated when Telegram fails)
pipeline/logs/watchdog_alerts.log

# Website runtime data — written by scheduled tasks (deploy_helper, eod_review,
# eod_track_record, daily_dump, morning_scan). Site deploy is muted since
# 2026-04-26 re-validation, so these files exist locally but must not be
# committed. Without this rule every `git status` is polluted by 6+ modified
# files and there's a real risk of accidentally committing one.
data/articles_index.json
data/gap_risk.json
data/global_regime.json
data/live_status.json
data/today_recommendations.json
data/track_record.json
