[Unit]
Description=Anka TA Karpathy v1 — daily forward prediction (04:30 IST)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=anka
Group=anka
WorkingDirectory=/home/anka/askanka.com
EnvironmentFile=/home/anka/askanka.com/pipeline/.env
ExecStart=/home/anka/askanka.com/.venv/bin/python -X utf8 -m pipeline.ta_scorer.karpathy_predict
StandardOutput=append:/home/anka/askanka.com/pipeline/logs/ta_karpathy_predict.log
StandardError=append:/home/anka/askanka.com/pipeline/logs/ta_karpathy_predict.log
Nice=10
TimeoutStartSec=15min
